const express = require("express");
const crypto = require("crypto");
const Razorpay = require("razorpay");
const { protect } = require("../middleware/auth");

const router = express.Router();

const razorpay = new Razorpay({
  key_id: process.env.RAZORPAY_KEY_ID,
  key_secret: process.env.RAZORPAY_KEY_SECRET,
});

// POST /api/payment/create-order  { amount }  -> amount in rupees
// Called from the frontend right before opening the Razorpay checkout popup.
router.post("/create-order", protect, async (req, res) => {
  try {
    const { amount } = req.body;
    if (!amount || amount <= 0) return res.status(400).json({ message: "A valid amount is required" });

    const order = await razorpay.orders.create({
      amount: Math.round(amount * 100), // Razorpay expects paise
      currency: "INR",
      receipt: "rcpt_" + Date.now(),
    });

    res.json({ orderId: order.id, amount: order.amount, currency: order.currency, keyId: process.env.RAZORPAY_KEY_ID });
  } catch (err) {
    res.status(500).json({ message: "Could not create payment order", error: err.message });
  }
});

// POST /api/payment/verify  { razorpay_order_id, razorpay_payment_id, razorpay_signature }
// Verifies the cryptographic signature Razorpay returns after a successful payment.
// Always verify on the server — never trust a "success" message from the frontend alone.
router.post("/verify", protect, async (req, res) => {
  try {
    const { razorpay_order_id, razorpay_payment_id, razorpay_signature } = req.body;

    const expectedSignature = crypto
      .createHmac("sha256", process.env.RAZORPAY_KEY_SECRET)
      .update(`${razorpay_order_id}|${razorpay_payment_id}`)
      .digest("hex");

    const isValid = expectedSignature === razorpay_signature;
    if (!isValid) return res.status(400).json({ verified: false, message: "Payment signature mismatch" });

    res.json({ verified: true });
  } catch (err) {
    res.status(500).json({ message: "Verification failed", error: err.message });
  }
});

module.exports = router;
